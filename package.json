{
  "private": true,
  "name": "encrypter",
  "version": "0.1.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "build:watch": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build --watch",
    "deploy": "npm run type-check && npm run lint && npm run test && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint src",
    "lines:check": "node --experimental-strip-types ./scripts/check-lines.ts",
    "check:preview-bundle": "node ./scripts/check-preview-bundle.mjs",
    "login": "devvit login",
    "test:rapid-input": "vitest run src/client/game.test.ts -t stale",
    "prettier": "prettier-package-json --write ./package.json && prettier --write .",
    "test": "vitest run",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/protos": "0.13.0",
    "@devvit/web": "0.13.0",
    "@hono/node-server": "1.19.8",
    "@hono/trpc-server": "0.4.2",
    "@trpc/client": "11.8.1",
    "@trpc/server": "11.8.1",
    "canvas-confetti": "^1.9.4",
    "clsx": "2.1.1",
    "hono": "4.11.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "3.4.0",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@devvit/start": "0.13.0",
    "vitest": "4.0.16",
    "@eslint/js": "9.39.2",
    "@tailwindcss/vite": "4.1.18",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/coverage-v8": "4.0.16",
    "devvit": "0.13.0",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "fallow": "^2.88.3",
    "fast-check": "^3.22.0",
    "globals": "14.0.0",
    "prettier": "3.7.4",
    "prettier-package-json": "2.8.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.1.18",
    "typescript": "5.8.3",
    "typescript-eslint": "8.53.0",
    "vite": "7.3.1"
  }
}
