{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "decrypttest",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "preview.html",
        "height": "tall"
      },
      "game": {
        "entry": "game.html",
        "height": "tall"
      },
      "shop": {
        "entry": "shop.html",
        "height": "tall"
      },
      "quest": {
        "entry": "quest.html",
        "height": "tall"
      },
      "stats": {
        "entry": "stats.html",
        "height": "tall"
      },
      "leaderboard": {
        "entry": "leaderboard.html",
        "height": "tall"
      }
    }
  },
  "media": {
    "dir": "public"
  },
  "marketingAssets": {
    "icon": "public/icon.png"
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new Decrypt post",
        "description": "Create Decrypt post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Decrypt: Reroll Daily Puzzle",
        "description": "Reroll and publish a new daily puzzle",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mod-reroll"
      },
      {
        "label": "Decrypt: Post Last Generated Challenge",
        "description": "Publish the staged daily challenge if posting failed",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mod-post-last-generated"
      },
      {
        "label": "Decrypt: Inject Manual Puzzle",
        "description": "Inject custom puzzle text",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mod-inject"
      },
      {
        "label": "Decrypt: Difficulty Calibration Status",
        "description": "Review shadow calibration readiness and tier drift",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mod-difficulty-calibration"
      },
      {
        "label": "Decrypt: Clear Subreddit Game Data",
        "description": "Clear this subreddit's Decrypt game data, including players, challenges, and progress",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/mod-clear-subreddit-data"
      }
    ]
  },
  "forms": {
    "mod_inject_form": "/internal/forms/mod-inject-submit",
    "mod_inject_review_form": "/internal/forms/mod-inject-review-submit",
    "mod_difficulty_calibration_status_form": "/internal/forms/mod-difficulty-calibration-status-submit",
    "mod_clear_subreddit_data_form": "/internal/forms/mod-clear-subreddit-data-submit"
  },
  "scheduler": {
    "tasks": {
      "decrypt-generate-daily-2200": {
        "endpoint": "/internal/scheduler/generate-daily",
        "cron": "0 22 * * *"
      },
      "decrypt-publish-daily-0000": {
        "endpoint": "/internal/scheduler/publish-daily",
        "cron": "0 0 * * *"
      },
      "decrypt-publish-daily-1200": {
        "endpoint": "/internal/scheduler/publish-daily",
        "cron": "0 12 * * *"
      },
      "decrypt-verify-daily-1810": {
        "endpoint": "/internal/scheduler/verify-daily",
        "cron": "10 18 * * *"
      },
      "decrypt-cleanup-journals-0300": {
        "endpoint": "/internal/scheduler/cleanup-completion-journals",
        "cron": "0 3 * * *"
      },
      "decrypt-calibrate-difficulty-v3": {
        "endpoint": "/internal/scheduler/calibrate-difficulty-v3",
        "cron": "30 3 * * *"
      }
    }
  },
  "settings": {
    "global": {
      "geminiApiKey": {
        "type": "string",
        "label": "Gemini API Key",
        "isSecret": true
      }
    },
    "subreddit": {
      "publishHourUtc": {
        "type": "number",
        "label": "Daily publish hour UTC (informational - scheduler uses fixed slots)",
        "defaultValue": 0
      },
      "timezone": {
        "type": "string",
        "label": "Timezone label",
        "defaultValue": "UTC"
      },
      "dailyAutomationEnabled": {
        "type": "select",
        "label": "Daily automation enabled",
        "options": [
          {
            "label": "Enabled",
            "value": "enabled"
          },
          {
            "label": "Disabled",
            "value": "disabled"
          }
        ],
        "defaultValue": "enabled"
      },
      "logicalCipherPercent": {
        "type": "number",
        "label": "Logical cipher frequency percent",
        "defaultValue": 10,
        "validationEndpoint": "/internal/settings/validate-logical-percent"
      },
      "aiMaxRetries": {
        "type": "number",
        "label": "AI max retries",
        "defaultValue": 3,
        "validationEndpoint": "/internal/settings/validate-ai-retries"
      },
      "contentSafetyMode": {
        "type": "select",
        "label": "Content safety mode",
        "options": [
          {
            "label": "Strict",
            "value": "strict"
          },
          {
            "label": "Balanced",
            "value": "balanced"
          }
        ],
        "defaultValue": "strict"
      }
    }
  },
  "payments": {
    "productsFile": "./products.json",
    "endpoints": {
      "fulfillOrder": "/internal/payments/fulfill",
      "refundOrder": "/internal/payments/refund"
    }
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "generativelanguage.googleapis.com"
      ]
    },
    "redis": true,
    "payments": true,
    "reddit": {
      "enable": true,
      "asUser": [
        "SUBMIT_POST",
        "SUBMIT_COMMENT",
        "SUBSCRIBE_TO_SUBREDDIT"
      ]
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onAppUpgrade": "/internal/triggers/on-app-upgrade"
  },
  "scripts": {
    "dev": "npm run build:watch",
    "build": "npm run build"
  },
  "dev": {
    "subreddit": "decrypttest_dev"
  }
}
