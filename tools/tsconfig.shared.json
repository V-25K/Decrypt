{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "WebWorker", "ES2023"],

    "outDir": "../dist/types/shared",

    "tsBuildInfoFile": "../dist/types/shared/tsconfig.tsbuildinfo",

    "rootDir": "../src/shared"
  },
  "include": ["../src/shared/**/*"],
  "exclude": [
    "../src/shared/**/*.test.ts",
    "../src/shared/**/*.test.tsx",
    "../src/shared/**/*.spec.ts",
    "../src/shared/**/*.spec.tsx",
    "../src/shared/**/*property*.ts"
  ]
}
